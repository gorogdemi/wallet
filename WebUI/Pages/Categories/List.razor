@page "/categories"
@inherits CategoryBase
@inject IDialogService DialogService

<h1>Categories</h1>

<FluentButton Class="mt-3 mb-3" IconStart="@(new Filled.Size20.AddCircle())" Appearance="Appearance.Accent" OnClick="AddAsync" Loading="IsLoading">
    New category
</FluentButton>

<FluentCard Class="d-grid p-0" Style="min-height: 300px;" Width="100%" Height="auto">
    <FluentDataGrid @ref="_dataGrid"
                    ItemsProvider="_categoryProvider"
                    GridTemplateColumns="1fr"
                    Loading="true"
                    RowSize="DataGridRowSize.Medium"
                    Pagination="@_pagination"
                    Style="overflow-x: auto;">
        <ChildContent>
            <PropertyColumn Title="Name" Property="@(c => c.Name)" Tooltip="true" Sortable="true" Align="Align.Start" IsDefaultSortColumn="true" />
            <TemplateColumn Title="Action">
                <EditorButtons OnEdit="() => EditAsync(context)" OnDelete="() => DeleteAsync(context)" />
            </TemplateColumn>
        </ChildContent>
    </FluentDataGrid>

    <FluentPaginator Class="mx-3" State="@_pagination" />
</FluentCard>

@code {

    private readonly PaginationState _pagination = new() { ItemsPerPage = 3 };
    private FluentDataGrid<CategoryDto> _dataGrid;
    private GridItemsProvider<CategoryDto> _categoryProvider;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        _categoryProvider = async request =>
        {
            _dataGrid.SetLoadingState(true);

            var providerResult = new GridItemsProviderResult<CategoryDto> { Items = [], TotalItemCount = 0 };

            var sortedProperty = request.GetSortByProperties().First();

            await HandleRequestAsync(
                async () => await Service.GetAllAsync(
                    new GetPaginatedListRequest
                    {
                        PageNumber = _pagination.CurrentPageIndex + 1,
                        PageSize = _pagination.ItemsPerPage,
                        SortBy = sortedProperty.PropertyName,
                        SortByAscending = sortedProperty.Direction is SortDirection.Ascending,

                        // NameFilter = SearchTerm,
                    }),
                categories =>
                {
                    ViewModel = categories;
                    _dataGrid.SetLoadingState(false);
                    providerResult = GridItemsProviderResult.From(ViewModel.Items, ViewModel.TotalCount!.Value);
                });

            return providerResult;
        };
    }

    protected override async Task SetViewModelAsync() => ViewModel = new PaginatedList<CategoryDto>();

    private async Task AddAsync() => await HandleDialogAsync(id: null, new CategoryRequest());

    private async Task EditAsync(CategoryDto category) => await HandleDialogAsync(category.Id, new CategoryRequest { Name = category.Name });

    private async Task HandleDialogAsync(string id, CategoryRequest categoryRequest)
    {
        var isEdit = !string.IsNullOrEmpty(id);

        DialogParameters parameters = new()
        {
            Title = $"{(isEdit ? "Edit" : "Create")} category",
            Width = "500px",
            TrapFocus = true,
            Modal = true,
            PreventScroll = true,
        };

        var dialog = await DialogService.ShowDialogAsync<CategoryFormDialog>(categoryRequest, parameters);
        var result = await dialog.Result;

        if (result.Data is not null)
        {
            var request = result.Data as CategoryRequest;

            await HandleRequestAsync(
                async () => await (isEdit ? Service.UpdateAsync(id, request) : Service.CreateAsync(request)),
                async () => await _dataGrid.RefreshDataAsync());
        }
    }

    private async Task DeleteAsync(CategoryDto category)
    {
        var dialog = await DialogService.ShowConfirmationAsync("Are you sure about deleting the category?", title: "Delete category");
        var result = await dialog.Result;

        if (!result.Cancelled)
        {
            await HandleRequestAsync(
                async () => await Service.DeleteAsync(category.Id),
                async () => await _dataGrid.RefreshDataAsync());
        }
    }

}