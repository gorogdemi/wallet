@page "/transactions"
@inherits TransactionBase<TransactionViewModel>
@inject IDialogService DialogService

<h1>Transactions</h1>

<FluentButton Class="mt-3 mb-3"
              IconStart="@(new Filled.Size20.AddCircle())"
              Appearance="Appearance.Accent"
              OnClick="AddAsync"
              Loading="IsLoading"
              Disabled="@(ViewModel?.Categories is null)">
    New transaction
</FluentButton>

<FluentToolbar Orientation="Orientation.Horizontal" Class="mb-3 w-100">
    <FluentSearch @bind-Value="NameFilter" @bind-Value:after="DataGridRefreshDataAsync" Autofocus="true" Placeholder="Name..." />
    <FluentSelect Placeholder="All types"
                  @bind-SelectedOption="TypeFilterValue"
                  @bind-SelectedOption:after="DataGridRefreshDataAsync"
                  Items="_transactionTypes"
                  OptionText="type => type!.Value.ToTransactionTypeText()"
                  Width="180px" />
    @if (TypeFilterValue.HasValue)
    {
        <FluentButton OnClick="ClearTypeFilterAsync" Style="height: 32px">
            <FluentIcon Icon="Regular.Size20.Dismiss" Color="Color.Neutral" />
        </FluentButton>
    }
    <FluentSelect Placeholder="All categories"
                  @bind-Value="CategoryIdFilter"
                  @bind-Value:after="DataGridRefreshDataAsync"
                  Items="ViewModel?.Categories"
                  OptionText="o => o?.Name.ToCategoryText()"
                  OptionValue="o => o?.Id"
                  Width="220px"
                  Disabled="@(ViewModel?.Categories is null)" />
    @if (!string.IsNullOrEmpty(CategoryIdFilter))
    {
        <FluentButton OnClick="ClearCategoryFilterAsync" Style="height: 32px">
            <FluentIcon Icon="Regular.Size20.Dismiss" Color="Color.Neutral" />
        </FluentButton>
    }
    <FluentButton IconStart="@(new Filled.Size20.ArrowClockwise())" Appearance="Appearance.Accent" Loading="IsTableLoading" OnClick="DataGridRefreshDataAsync">
        Search
    </FluentButton>
</FluentToolbar>

<FluentCard Class="d-grid p-0" Style="min-height: 300px;" Width="100%" Height="auto">
    <FluentDataGrid @ref="_dataGrid"
                    Items="_transactions"
                    RefreshItems="RefreshItemsAsync"
                    GridTemplateColumns="0.5fr 0.2fr 0.2fr 0.2fr 0.2fr 0.2fr 0.2fr 0.4fr 0.2fr"
                    ResizableColumns="true"
                    Loading="@(IsLoading || IsTableLoading)"
                    RowSize="DataGridRowSize.Medium"
                    Pagination="@_pagination"
                    Style="overflow-x: auto;">
        <ChildContent>
            <PropertyColumn Title="Name" Property="@(c => c.Name)" Sortable="true" Tooltip="true" Align="Align.Start" IsDefaultSortColumn="true" />
            <PropertyColumn Title="Full" Property="@(c => c.SumAmount)" Format="0 Ft" Align="Align.End" />
            <PropertyColumn Title="Cash" Property="@(c => c.CashAmount)" Format="0 Ft" Sortable="true" Align="Align.End" />
            <PropertyColumn Title="Bank" Property="@(c => c.BankAmount)" Format="0 Ft" Sortable="true" Align="Align.End" />
            <PropertyColumn Title="Date" Property="@(c => c.Date)" Format="yyyy.MM.dd" Sortable="true" Align="Align.Start" />
            <PropertyColumn Title="Type" Property="@(c => c.Type.ToTransactionTypeText())" Align="Align.Start" />
            <PropertyColumn Title="Category" Property="@(c => c.CategoryName.ToCategoryText())" Align="Align.Start" />
            <PropertyColumn Title="Comment" Property="@(c => c.Comment)" Tooltip="true" Align="Align.Start" />
            <TemplateColumn Title="Action">
                <EditorButtons OnEdit="() => EditAsync(context)" OnDelete="() => DeleteAsync(context.Id)" />
            </TemplateColumn>
        </ChildContent>
    </FluentDataGrid>

    <FluentPaginator Class="mx-3" State="@_pagination" />
</FluentCard>

@code {

    private readonly PaginationState _pagination = new() { ItemsPerPage = 3 };
    private FluentDataGrid<TransactionDto> _dataGrid;
    private IQueryable<TransactionDto> _transactions;
    private List<TransactionType?> _transactionTypes = [];

    private bool IsTableLoading
    {
        get;
        set
        {
            field = value;
            StateHasChanged();
        }
    }

    [SupplyParameterFromQuery]
    private int Page { get; set; }

    [SupplyParameterFromQuery]
    private string SortBy { get; set; }

    [SupplyParameterFromQuery]
    private bool Ascending { get; set; }

    [SupplyParameterFromQuery]
    private string NameFilter { get; set; }

    [SupplyParameterFromQuery]
    private string CategoryIdFilter { get; set; }

    [SupplyParameterFromQuery]
    private string TypeFilterQuery { get; set; }

    private TransactionType? TypeFilterValue { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _transactionTypes = Enum.GetValues<TransactionType>().Cast<TransactionType?>().ToList();

        if (!string.IsNullOrWhiteSpace(TypeFilterQuery)
            && Enum.TryParse(TypeFilterQuery, ignoreCase: true, out TransactionType parsedType))
        {
            TypeFilterValue = parsedType;
        }

        await _pagination.SetCurrentPageIndexAsync(Page >= 1 ? Page - 1 : 0);
        await base.OnInitializedAsync();
    }

    protected override async Task SetViewModelAsync()
    {
        await HandleRequestAsync(
            async () =>
            {
                var categories = await Service.CategoryService.GetAllAsync(new GetCategoriesRequest());

                return new TransactionViewModel
                {
                    Categories = categories.Items,
                };
            },
            async viewModel =>
            {
                ViewModel = viewModel;
                await DataGridRefreshDataAsync();
            });
    }

    private async Task RefreshItemsAsync(GridItemsProviderRequest<TransactionDto> request)
    {
        if (ViewModel is null)
        {
            return;
        }

        IsTableLoading = true;

        var sortedProperty = request.GetSortByProperties().First();
        var sortBy = sortedProperty.PropertyName;
        var ascending = sortedProperty.Direction is SortDirection.Ascending;

        if (!string.IsNullOrEmpty(SortBy))
        {
            sortBy = SortBy;
            ascending = Ascending;
        }

        await HandleRequestAsync(
            async () => await Service.TransactionService.GetAllAsync(
                new GetTransactionsRequest
                {
                    PageNumber = _pagination.CurrentPageIndex + 1,
                    PageSize = _pagination.ItemsPerPage,
                    SortBy = sortBy,
                    SortByAscending = ascending,
                    NameFilter = NameFilter,
                    CategoryIdFilter = CategoryIdFilter,
                    TypeFilter = TypeFilterValue,
                }),
            async transactions =>
            {
                ViewModel.Transactions = transactions;
                _transactions = ViewModel.Transactions.Items.AsQueryable();
                await _pagination.SetTotalItemCountAsync(ViewModel.Transactions.TotalCount!.Value);
            });

        NavigationManager.UpdateBrowserUriQueryParameters(
            new Dictionary<string, object>
            {
                ["page"] = _pagination.CurrentPageIndex + 1,
                ["sortBy"] = sortBy,
                ["ascending"] = ascending,
                ["nameFilter"] = NameFilter,
                ["categoryIdFilter"] = CategoryIdFilter,
                ["typeFilter"] = TypeFilterQuery,
            });

        IsTableLoading = false;
    }

    private async Task AddAsync() => await HandleDialogAsync(null);

    private async Task EditAsync(TransactionDto transaction) => await HandleDialogAsync(transaction.Id);

    private async Task HandleDialogAsync(string id)
    {
        var isEdit = !string.IsNullOrEmpty(id);
        var formViewModel = SetFormViewModel(id, isEdit);

        DialogParameters parameters = new()
        {
            Title = $"{(isEdit ? "Edit" : "Create")} transaction",
            Width = "500px",
            TrapFocus = true,
            Modal = true,
            PreventScroll = true,
        };

        var dialog = await DialogService.ShowDialogAsync<TransactionFormDialog>(formViewModel, parameters);
        var result = await dialog.Result;

        if (result.Data is not null)
        {
            var viewModel = result.Data as TransactionFormViewModel;
            await SaveTransactionAsync(id, viewModel, isEdit);
        }
    }

    private TransactionFormViewModel SetFormViewModel(string id, bool isEdit)
    {
        var formViewModel = new TransactionFormViewModel
        {
            Categories = ViewModel.Categories,
        };

        if (isEdit)
        {
            var transaction = ViewModel.Transactions.Items.Find(x => x.Id == id);
            formViewModel.Name = transaction!.Name;
            formViewModel.Comment = transaction.Comment;
            formViewModel.BankAmount = transaction.BankAmount;
            formViewModel.CashAmount = transaction.CashAmount;
            formViewModel.Date = transaction.Date;
            formViewModel.CategoryId = transaction.CategoryId;
            formViewModel.Type = transaction.Type;
        }

        return formViewModel;
    }

    private async Task SaveTransactionAsync(string id, TransactionFormViewModel viewModel, bool isEdit)
    {
        var request = new TransactionRequest
        {
            Name = viewModel!.Name,
            Comment = viewModel.Comment,
            BankAmount = viewModel.BankAmount,
            CashAmount = viewModel.CashAmount,
            Date = viewModel.Date,
            CategoryId = viewModel.CategoryId,
            Type = viewModel.Type,
        };

        await HandleRequestAsync(
            async () => await (isEdit ? Service.TransactionService.UpdateAsync(id, request) : Service.TransactionService.CreateAsync(request)),
            DataGridRefreshDataAsync);
    }

    private async Task DeleteAsync(string id)
    {
        var dialog = await DialogService.ShowConfirmationAsync("Are you sure about deleting the transaction?", title: "Delete transaction");
        var result = await dialog.Result;

        if (!result.Cancelled)
        {
            await HandleRequestAsync(
                async () => await Service.TransactionService.DeleteAsync(id),
                DataGridRefreshDataAsync);
        }
    }

    private async Task ClearTypeFilterAsync()
    {
        TypeFilterValue = null;
        TypeFilterQuery = null;
        await DataGridRefreshDataAsync();
    }

    private async Task ClearCategoryFilterAsync()
    {
        CategoryIdFilter = null;
        await DataGridRefreshDataAsync();
    }

    private async Task DataGridRefreshDataAsync()
    {
        TypeFilterQuery = TypeFilterValue?.ToString();
        await _dataGrid.RefreshDataAsync(true);
    }

}